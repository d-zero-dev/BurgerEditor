{
	"name": "@burger-editor/inspector",
	"version": "4.0.0-alpha.57",
	"description": "BurgerEditor HTML inspection and search utilities",
	"author": "D-ZERO",
	"license": "(MIT OR Apache-2.0)",
	"repository": {
		"url": "https://github.com/d-zero-dev/BurgerEditor.git"
	},
