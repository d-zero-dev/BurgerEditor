{
	"extends": ["./tsconfig.json"],
	"compilerOptions": {
		"noEmit": false,
		"outDir": "./server",
		"rootDir": "./src",
		"declaration": true,
		"declarationMap": true
	},
	"include": ["./src/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"import",
		"server",
		"./src/**/*.spec.ts",
		"./src/client/**/*",
		"./src/import/**/*"
	]
}
