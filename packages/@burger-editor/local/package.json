{
	"name": "@burger-editor/local",
	"version": "4.0.0-alpha.20",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./server/types.d.ts"
		}
	},
	"bin": {
		"bge": "./server/index.js"
	},
	"files": [
		"dist",
		"server",
		"style"
	],
	"scripts": {
		"build": "run-p build:client build:server",
		"build:client": "vite build",
		"build:server": "tsc -p tsconfig.build.json",
		"prebuild": "tsc",
		"dev": "run-p dev:client dev:server",
		"dev:client": "vite build --watch",
		"dev:server": "DEV_MODE=true DEBUG=\"@bge:*\" tsx watch src/index.ts"
	},
	"dependencies": {
		"@hono/node-server": "1.19.3",
		"@hono/zod-validator": "0.7.2",
		"ansi-colors": "4.1.3",
		"cosmiconfig": "9.0.0",
		"debug": "4.4.3",
		"gray-matter": "^4.0.3",
		"hono": "4.9.7",
		"jsdom": "26.1.0",
		"open": "10.2.0",
		"prettier": "3.6.2",
		"zod": "4.0.17"
	},
	"devDependencies": {
		"@burger-editor/blocks": "4.0.0-alpha.20",
		"@burger-editor/client": "4.0.0-alpha.20",
		"@burger-editor/core": "4.0.0-alpha.20",
		"@types/debug": "4.1.12",
		"@types/jsdom": "21.1.7",
		"@types/node": "24.5.1",
		"dotenv": "17.2.2",
		"npm-run-all2": "8.0.4",
		"tsx": "4.20.5",
		"vite": "7.1.5"
	},
	"author": "D-ZERO",
	"license": "(MIT OR Apache-2.0)"
}
