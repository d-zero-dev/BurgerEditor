{
	"name": "@burger-editor/local",
	"version": "4.0.0-alpha.48",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"types": "./server/types.d.ts"
		},
		"./import": {
			"import": "./import/index.js",
			"types": "./import/index.d.ts"
		}
	},
	"bin": {
		"bge": "./server/index.js"
	},
	"files": [
		"dist",
		"import",
		"server",
		"style"
	],
	"scripts": {
		"build": "npx run-p build:check build:client build:import build:server",
		"build:client": "vite build",
		"build:import": "npx tsc -p tsconfig.import.build.json",
		"build:server": "npx tsc -p tsconfig.build.json",
		"build:check": "npx tsc",
		"dev": "npx run-p dev:client dev:server",
		"dev:client": "vite build --watch",
		"dev:server": "DEV_MODE=true DEBUG=\"@bge:*\" tsx watch src/index.ts"
	},
	"dependencies": {
		"@burger-editor/blocks": "4.0.0-alpha.48",
		"@hono/node-server": "1.19.7",
		"@hono/zod-validator": "0.7.6",
		"ansi-colors": "4.1.3",
		"cosmiconfig": "9.0.0",
		"debug": "4.4.3",
		"gray-matter": "^4.0.3",
		"hono": "4.11.3",
		"jsdom": "27.4.0",
		"open": "11.0.0",
		"prettier": "3.7.4",
		"zod": "4.3.5"
	},
	"devDependencies": {
		"@burger-editor/client": "4.0.0-alpha.48",
		"@burger-editor/core": "4.0.0-alpha.48",
		"@types/debug": "4.1.12",
		"@types/jsdom": "27.0.0",
		"@types/node": "24.10.4",
		"dotenv": "17.2.3",
		"tsx": "4.21.0",
		"vite": "7.3.1"
	},
	"author": "D-ZERO",
	"license": "(MIT OR Apache-2.0)"
}
