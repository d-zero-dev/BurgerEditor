{
	"name": "@burger-editor/file-io",
	"version": "4.0.0-alpha.66",
	"description": "Node.js side file I/O for BurgerEditor v4 — config loader, page load/save, file tree, virtual path resolver. Initializes globalThis.DOMParser via jsdom so @burger-editor/core can run outside the browser.",
	"author": "D-ZERO",
	"license": "(MIT OR Apache-2.0)",
	"repository": {
		"type": "git",
		"url": "https://github.com/d-zero-dev/BurgerEditor.git",
		"directory": "packages/@burger-editor/file-io"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --watch --project tsconfig.build.json",
		"clean": "tsc --build --clean"
	},
	"dependencies": {
		"@burger-editor/blocks": "4.0.0-alpha.66",
		"@burger-editor/core": "4.0.0-alpha.66",
		"@burger-editor/utils": "4.0.0-alpha.66",
		"cosmiconfig": "9.0.0",
		"jsdom": "28.1.0",
		"prettier": "3.8.1"
	},
	"devDependencies": {
		"@types/jsdom": "28.0.1",
		"@types/node": "24.11.0"
	}
}
